# Dam data URL (default: Ure Dam)
# DAM_URL=https://www.water.go.jp/mizu/chubu/realtime/p020201_60/301_1.html

# Dam history cache file path
DAM_CACHE_FILE=dam_history.json

# S3 (for Lambda deployment)
S3_BUCKET=
S3_OBJECT_KEY=

# Lambda IAM Role ARN (for lambroll deploy)
LAMBDA_ROLE_ARN=

# Timezone
TZ=Asia/Tokyo
