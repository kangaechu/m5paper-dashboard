# Dam data URL (default: 荒川水系 4ダム貯水状況 / MLIT 関東地方整備局)
# DAM_URL=https://www.ktr.mlit.go.jp/river/shihon/river_shihon00000113.html

# Dam history cache file path
DAM_CACHE_FILE=dam_history.json

# S3 (for Lambda deployment)
S3_BUCKET=
S3_OBJECT_KEY=

# Lambda IAM Role ARN (for lambroll deploy)
LAMBDA_ROLE_ARN=

# Timezone
TZ=Asia/Tokyo
