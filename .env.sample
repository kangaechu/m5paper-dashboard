# JMA location code (130000=Tokyo)
LOCATION_CODE=130000

# Latitude/Longitude for hourly weather (Open-Meteo)
LOCATION_LAT=35.6895
LOCATION_LON=139.6917

# Google Calendar: base64-encoded service account JSON key
# echo -n '{"type":"service_account",...}' | base64
GOOGLE_CREDENTIALS_JSON=

# Google Calendar IDs (comma-separated)
GOOGLE_CALENDAR_IDS=primary

# Train lines to watch (name:yahoo_code pairs, comma-separated)
# Codes: https://transit.yahoo.co.jp/traininfo/detail/{code}/
TRAIN_LINES=山手線:21/0,銀座線:132/0,丸ノ内線:133/0,日比谷線:134/0,東西線:135/0,千代田線:136/0,有楽町線:137/0,半蔵門線:138/0,南北線:139/0,副都心線:540/0,浅草線:128/0,三田線:129/0,新宿線:130/0,大江戸線:131/0

# S3 (for Lambda deployment)
S3_BUCKET=
S3_OBJECT_KEY=

# Lambda IAM Role ARN (for lambroll deploy)
LAMBDA_ROLE_ARN=

# Timezone
TZ=Asia/Tokyo
